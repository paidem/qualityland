{% extends "base.njk" %}
{% block title %}{{ speaker.name }}{% endblock %}
{% block content %}
<section class="speaker-page">
  <div class="container">
    <a href="/#speakers" class="speaker-page__back">&larr; Back to speakers</a>

    <div class="speaker-page__layout">
      <div class="speaker-page__photo-col">
        <div class="speaker-page__photo">
          <img src="/{{ speaker.photo }}" alt="{{ speaker.name }}" width="600" height="600">
        </div>

        {% if speaker.linkedin %}
        <a href="{{ speaker.linkedin }}" target="_blank" rel="noopener noreferrer" class="speaker-page__linkedin btn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          Connect on LinkedIn
        </a>
        {% endif %}
      </div>

      <div class="speaker-page__info-col">
        <h1 class="speaker-page__name">{{ speaker.name }}</h1>
        <p class="speaker-page__role">
          {{ speaker.title }}{% if speaker.company %} at {{ speaker.company }}{% endif %}, {{ speaker.country }}
        </p>

        {% if speaker.talk %}
        <div class="speaker-page__talk">
          <span class="speaker-page__talk-label">Talk</span>
          <p class="speaker-page__talk-title">{{ speaker.talk.title }}</p>
        </div>
        {% endif %}

        <div class="speaker-page__bio">
          {{ speaker.bio | nl2br | safe }}
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}
