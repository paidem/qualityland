<header class="nav" id="nav">
  <div class="nav__inner container">
    <a href="/" class="nav__logo">
      <img src="/images/logos/ql-logo.png" alt="Quality Land" width="160" height="50">
    </a>

    <input type="checkbox" id="nav-toggle" class="nav__toggle-checkbox" aria-label="Toggle navigation">
    <label for="nav-toggle" class="nav__toggle-btn" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <nav class="nav__links" role="navigation">
      {% for item in site.nav %}
        <a href="{{ item.href }}" class="nav__link">{{ item.label }}</a>
      {% endfor %}
    </nav>
  </div>
</header>
